<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Помощник преподавателя"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp" />

    <Button
        android:id="@+id/btnAttendance"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Отметить посещаемость"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnReminder"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Напомнить о следующей паре"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnPhotoBoard"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Сфотографировать доску"
        android:layout_marginBottom="40dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Сегодняшние пары:\n1. Мобильная разработка (10:00)\n2. Базы данных (13:30)"
        android:textSize="16sp" />

</LinearLayout>